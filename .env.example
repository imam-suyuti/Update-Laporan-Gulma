# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Workspace OAuth Integration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_SPREADSHEET_ID=""

# Microsoft SQL Server (MS SQL) Configuration (Optional - falls back to Google Sheets & local JSON if not supplied)
MSSQL_SERVER=""
MSSQL_USER=""
MSSQL_PASSWORD=""
MSSQL_DATABASE=""
MSSQL_PORT="1433"
MSSQL_ENCRYPT="true"

# MySQL / MariaDB (phpMyAdmin) Configuration (Optional - falls back to Google Sheets & local JSON if not supplied)
MYSQL_HOST=""
MYSQL_USER=""
MYSQL_PASSWORD=""
MYSQL_DATABASE=""
MYSQL_PORT="3306"
DB_TYPE="mysql" # Set to "mysql" or "mssql" depending on your hosting database


